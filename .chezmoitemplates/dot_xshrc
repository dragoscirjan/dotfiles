# Override cat to use bat (-> https://github.com/sharkdp/bat) if available
#
cat() {
  local batcmd="- end"
  if [ -z "$NO_BAT" ]; then
    if command -v bat >/dev/null 2>&1; then
      batcmd="bat"
    elif command -v batcat >/dev/null 2>&1; then
      batcmd="batcat"
    fi
  fi
  if [ -n "$batcmd" ]; then
    # Map common cat options to bat equivalents
    local bat_args=()
    local files=()
    while [ $# -gt 0 ]; do
      case "$1" in
        -n)
          bat_args+=("--number")
          ;;
        -b)
          bat_args+=("--number-nonblank")
          ;;
        -s)
          bat_args+=("--squeeze-blank")
          ;;
        -A)
          bat_args+=("--show-all")
          ;;
        -T)
          bat_args+=("--show-tabs")
          ;;
        -E)
          bat_args+=("--show-ends")
          ;;
        --style=*)
          BAT_STYLE="${1#*=}"
          ;;
        --paging=*)
          BAT_PAGING=("${1#*=}")
          ;;
        --)
          shift
          while [ $# -gt 0 ]; do files+=("$1"); shift; done
          break
          ;;
        -*)
          bat_args+=("$1")
          ;;
        *)
          files+=("$1")
          ;;
      esac
      shift
    done
    BAT_STYLE="plain" BAT_PAGING="never" "$batcmd" "${bat_args[@]}" -- "${files[@]}"
  else
    command cat $@
  fi
}

