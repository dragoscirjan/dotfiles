# Override cd to
# - auto-use nvm when entering directories with .nvmrc
#
cd() {
  builtin cd $@
  if [ -d "$HOME/.nvm" ] && [ -f .nvmrc ]; then
    nvm use
  fi
}

if command -v exa >/dev/null 2>&1; then
  alias ls='exa --icons'
fi
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --icons'
fi

